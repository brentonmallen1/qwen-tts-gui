# ===========================================
# Qwen3-TTS Docker Configuration
# ===========================================
# Copy this file to .env and customize as needed

# ------------------------------------------
# Server Settings
# ------------------------------------------
# Port to expose the web interface
PORT=7860

# ------------------------------------------
# GPU Configuration
# ------------------------------------------
# GPU device ID(s) to use (comma-separated for multiple)
CUDA_VISIBLE_DEVICES=0

# Enable FlashAttention for better memory efficiency (requires compatible GPU)
USE_FLASH_ATTENTION=true

# ------------------------------------------
# Model Settings
# ------------------------------------------
# Which model sizes to download/enable (comma-separated: "0.6B", "1.7B", or "0.6B,1.7B")
# Note: Voice Design mode requires 1.7B - only Voice Clone and Custom Voice work with 0.6B
ENABLED_MODEL_SIZES=1.7B

# Preload models on startup (increases startup time but faster first inference)
PRELOAD_MODELS=false

# HuggingFace token (optional, only needed for private models)
HF_TOKEN=

# ------------------------------------------
# Authentication
# ------------------------------------------
# Enable basic HTTP authentication
AUTH_ENABLED=false

# Admin credentials (required if AUTH_ENABLED=true)
AUTH_USERNAME=admin
AUTH_PASSWORD=

# ------------------------------------------
# Security
# ------------------------------------------
# Maximum file upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Allowed audio MIME types for uploads (comma-separated)
ALLOWED_AUDIO_TYPES=audio/wav,audio/mpeg,audio/mp3,audio/x-wav,audio/wave,audio/x-pn-wav

# Allowed CORS origins (comma-separated, leave empty for localhost-only in dev)
# Example: https://myserver.local,https://tts.example.com
ALLOWED_ORIGINS=

# ------------------------------------------
# Logging
# ------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------------------
# Development
# ------------------------------------------
# Enable mock mode for testing UI without GPU (generates placeholder audio)
MOCK_MODE=false

# ------------------------------------------
# Storage Paths
# ------------------------------------------
# Host path for HuggingFace models (2-5GB per model)
# For Unraid: /mnt/user/appdata/qwen-tts/models or a cache drive
MODELS_PATH=./data/models

# Host path for app data (cache, output, personalities)
# For Unraid: /mnt/user/appdata/qwen-tts
DATA_PATH=./data

# ------------------------------------------
# Whisper Transcription
# ------------------------------------------
# Model size for audio transcription (used for personality creation)
# Options:
#   tiny    - ~75MB,  fastest, basic accuracy
#   base    - ~150MB, fast, good accuracy (recommended)
#   small   - ~500MB, medium speed, better accuracy
#   medium  - ~1.5GB, slow, high accuracy
#   large-v3 - ~3GB, slowest, best accuracy
WHISPER_MODEL=base

# ------------------------------------------
# Unraid / LinuxServer.io Compatibility
# ------------------------------------------
# User ID for file permissions
PUID=99

# Group ID for file permissions
PGID=100

# Timezone
TZ=America/New_York

# ------------------------------------------
# Docker Registry (for releases)
# ------------------------------------------
# Registry URL for publishing images (e.g., docker.io/username, ghcr.io/username)
DOCKER_REGISTRY=
