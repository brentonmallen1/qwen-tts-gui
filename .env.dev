# Development environment for Mac (no GPU)
HOST=0.0.0.0
PORT=7860
MOCK_MODE=true

# Auth disabled for local dev (enable to test auth flow)
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=devpassword

# Enable both sizes for testing UI (in production, default is just 0.6B)
ENABLED_MODEL_SIZES=0.6B,1.7B

MODEL_PATH=./data/models
CACHE_PATH=./data/cache
OUTPUT_PATH=./data/output
